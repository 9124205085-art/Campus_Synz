# Local development
VITE_API_URL=http://localhost:5000/api

# Vercel + Render (set ONE of these on Vercel, then redeploy)
# Option A — proxy (recommended): frontend calls /api on Vercel, forwarded to Render
# RENDER_API_URL=https://YOUR-SERVICE.onrender.com

# Option B — direct: browser calls Render (requires CORS_ORIGINS on Render)
# VITE_API_URL=https://YOUR-SERVICE.onrender.com/api
