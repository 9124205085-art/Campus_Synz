# Copy to backend/.env and adjust values

# PostgreSQL — use after installing PostgreSQL (password: campussynz_dev)
# DATABASE_URL=postgresql://postgres:campussynz_dev@localhost:5432/campussynz

# SQLite (default if DATABASE_URL is not set)
# DATABASE_URL=sqlite:///database/college.db

SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production

# Comma-separated frontend URLs allowed to call the API (required for Vercel)
# Example: https://campussynz.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
